<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#0b0f1e">
    <View android:layout_width="280dp" android:layout_height="280dp" android:layout_gravity="center_horizontal|top" android:layout_marginTop="-60dp" android:background="@drawable/bg_glow_top" />
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingStart="20dp" android:paddingEnd="12dp" android:paddingTop="12dp">
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="horizontal" android:gravity="center_vertical">
            <TextView android:id="@+id/toolbar_flag" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🌐" android:textSize="22sp" />
            <TextView android:id="@+id/toolbar_location" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="位置" android:textSize="13sp" android:textColor="#8892b0" android:layout_marginStart="8dp" />
        </LinearLayout>
        <ImageButton android:id="@+id/log_button" android:layout_width="40dp" android:layout_height="40dp" android:src="@android:drawable/ic_menu_info_details" android:background="?attr/selectableItemBackgroundBorderless" android:contentDescription="日志" android:tint="#8892b0" />
        <ImageButton android:id="@+id/settings_icon" android:layout_width="40dp" android:layout_height="40dp" android:src="@android:drawable/ic_menu_manage" android:background="?attr/selectableItemBackgroundBorderless" android:contentDescription="设置" android:tint="#8892b0" />
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center_horizontal" android:layout_gravity="center" android:layout_marginTop="-40dp" android:paddingHorizontal="28dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="USQUE" android:textSize="13sp" android:textColor="#4a5578" android:letterSpacing="0.35" android:layout_marginBottom="36dp" android:fontFamily="monospace" />
        <RelativeLayout android:layout_width="140dp" android:layout_height="140dp" android:layout_marginBottom="28dp">
            <View android:id="@+id/pulse_ring_outer" android:layout_width="140dp" android:layout_height="140dp" android:layout_centerInParent="true" android:background="@drawable/pulse_ring_outer" />
            <View android:id="@+id/pulse_ring" android:layout_width="120dp" android:layout_height="120dp" android:layout_centerInParent="true" android:background="@drawable/pulse_ring" />
            <Button android:id="@+id/connect_button" android:layout_width="100dp" android:layout_height="100dp" android:layout_centerInParent="true" android:text="连接" android:textSize="16sp" android:textStyle="bold" android:textColor="#ffffff" android:background="@drawable/connect_button_bg" android:stateListAnimator="@null" android:elevation="8dp" />
        </RelativeLayout>
        <TextView android:id="@+id/status_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="未连接" android:textSize="16sp" android:textColor="#636e84" android:letterSpacing="0.02" android:layout_marginBottom="32dp" />
        <LinearLayout android:id="@+id/info_row" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" android:visibility="gone" android:layout_marginBottom="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="10dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="72dp" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:padding="12dp" android:background="@drawable/info_card_bg" android:layout_marginEnd="6dp">
                    <TextView android:id="@+id/country_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🌐" android:textSize="26sp" />
                    <TextView android:id="@+id/country_label" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textSize="11sp" android:textColor="#8892b0" android:layout_marginTop="4dp" android:maxLines="1" android:ellipsize="end" />
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="72dp" android:layout_weight="1.2" android:orientation="vertical" android:gravity="center" android:padding="12dp" android:background="@drawable/info_card_bg" android:layout_marginStart="6dp">
                    <TextView android:id="@+id/exit_ip_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textSize="13sp" android:textColor="#e8ecf4" android:fontFamily="monospace" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="出口 IP" android:textSize="10sp" android:textColor="#4a5578" android:layout_marginTop="4dp" />
                </LinearLayout>
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <LinearLayout android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:padding="8dp" android:background="@drawable/info_card_bg" android:layout_marginEnd="6dp">
                    <TextView android:id="@+id/latency_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-- ms" android:textSize="15sp" android:textStyle="bold" android:textColor="#e8ecf4" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="延迟" android:textSize="10sp" android:textColor="#4a5578" android:layout_marginTop="2dp" />
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:padding="8dp" android:background="@drawable/info_card_bg" android:layout_marginStart="6dp" android:layout_marginEnd="6dp">
                    <TextView android:id="@+id/ip_version_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="IPv4" android:textSize="15sp" android:textStyle="bold" android:textColor="#e8ecf4" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="协议" android:textSize="10sp" android:textColor="#4a5578" android:layout_marginTop="2dp" />
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:padding="8dp" android:background="@drawable/info_card_bg" android:layout_marginStart="6dp">
                    <TextView android:id="@+id/total_data_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0 B" android:textSize="13sp" android:textStyle="bold" android:textColor="#e8ecf4" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="流量" android:textSize="10sp" android:textColor="#4a5578" android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout android:id="@+id/speed_row" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center" android:padding="12dp" android:background="@drawable/speed_bar_bg" android:visibility="gone">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="↓" android:textSize="14sp" android:textColor="#00d4aa" android:layout_marginEnd="6dp" />
            <TextView android:id="@+id/speed_down_text" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="0 KB/s" android:textSize="13sp" android:textColor="#00d4aa" android:fontFamily="monospace" />
            <View android:layout_width="1dp" android:layout_height="16dp" android:background="#1e2440" android:layout_marginHorizontal="16dp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="↑" android:textSize="14sp" android:textColor="#6c5ce7" android:layout_marginEnd="6dp" />
            <TextView android:id="@+id/speed_up_text" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="0 KB/s" android:textSize="13sp" android:textColor="#6c5ce7" android:fontFamily="monospace" />
        </LinearLayout>
    </LinearLayout>
    <LinearLayout android:id="@+id/preset_bar" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center" android:padding="16dp" android:layout_gravity="bottom" android:layout_marginBottom="8dp">
        <TextView android:id="@+id/current_preset_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="" android:textSize="11sp" android:textColor="#4a5578" android:fontFamily="monospace" />
    </LinearLayout>
</FrameLayout>
