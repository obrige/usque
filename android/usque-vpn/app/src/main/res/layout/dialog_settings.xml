<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="#ffffff">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="SNI (TLS Server Name)" android:textColor="#475569" android:textSize="12sp" android:layout_marginBottom="4dp" />
        <EditText android:id="@+id/sni_input" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="cdnjs.cloudflare.com" android:inputType="textUri"
            android:textColor="#0f172a" android:textColorHint="#94a3b8" android:backgroundTint="#cbd5e1" android:layout_marginBottom="14dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="IPv4 Endpoint (host:port)" android:textColor="#475569" android:textSize="12sp" android:layout_marginBottom="4dp" />
        <Spinner
            android:id="@+id/endpoint_v4_spinner"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginBottom="4dp" />
        <EditText android:id="@+id/endpoint_v4_input" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="或自定义输入 host:port" android:inputType="textUri"
            android:textColor="#0f172a" android:textColorHint="#94a3b8" android:backgroundTint="#cbd5e1" android:layout_marginBottom="14dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="IPv6 Endpoint ([host]:port)" android:textColor="#475569" android:textSize="12sp" android:layout_marginBottom="4dp" />
        <Spinner
            android:id="@+id/endpoint_v6_spinner"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginBottom="4dp" />
        <EditText android:id="@+id/endpoint_v6_input" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="或自定义输入 [host]:port" android:inputType="textUri"
            android:textColor="#0f172a" android:textColorHint="#94a3b8" android:backgroundTint="#cbd5e1" android:layout_marginBottom="14dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="DNS Servers (one per line)" android:textColor="#475569" android:textSize="12sp" android:layout_marginBottom="4dp" />
        <EditText android:id="@+id/dns_input" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="8.8.8.8&#10;8.8.4.4"
            android:inputType="textMultiLine" android:minLines="2" android:maxLines="4"
            android:textColor="#0f172a" android:textColorHint="#94a3b8" android:backgroundTint="#cbd5e1" android:layout_marginBottom="16dp" />

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#e2e8f0" android:layout_marginBottom="12dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Advanced MASQUE Config" android:textColor="#b91c1c" android:textSize="11sp" android:textStyle="bold" android:layout_marginBottom="10dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Client Private Key (Base64)" android:textColor="#475569" android:textSize="12sp" android:layout_marginBottom="4dp" />
        <EditText android:id="@+id/private_key_input" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="empty = auto-generate" android:inputType="textMultiLine" android:minLines="2" android:maxLines="3"
            android:textColor="#0f172a" android:textColorHint="#94a3b8" android:backgroundTint="#cbd5e1" android:layout_marginBottom="14dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Endpoint Public Key (PEM)" android:textColor="#475569" android:textSize="12sp" android:layout_marginBottom="4dp" />
        <EditText android:id="@+id/endpoint_pubkey_input" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="empty = auto" android:inputType="textMultiLine" android:minLines="2" android:maxLines="3"
            android:textColor="#0f172a" android:textColorHint="#94a3b8" android:backgroundTint="#cbd5e1" android:layout_marginBottom="14dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Device Name" android:textColor="#475569" android:textSize="12sp" android:layout_marginBottom="4dp" />
        <EditText android:id="@+id/device_name_input" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="Pixel 10" android:inputType="text"
            android:textColor="#0f172a" android:textColorHint="#94a3b8" android:backgroundTint="#cbd5e1" android:layout_marginBottom="16dp" />

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#e2e8f0" android:layout_marginBottom="12dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Spoofing / Identity" android:textColor="#475569" android:textSize="11sp" android:textStyle="bold" android:layout_marginBottom="8dp" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="10dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Device Model" android:textColor="#475569" android:textSize="11sp" />
                <EditText android:id="@+id/model_input" android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:hint="PC" android:inputType="text" android:textColor="#0f172a" android:textColorHint="#94a3b8" android:backgroundTint="#cbd5e1" />
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Locale" android:textColor="#475569" android:textSize="11sp" />
                <EditText android:id="@+id/locale_input" android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:hint="en_US" android:inputType="text" android:textColor="#0f172a" android:textColorHint="#94a3b8" android:backgroundTint="#cbd5e1" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="10dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="User-Agent" android:textColor="#475569" android:textSize="11sp" />
                <EditText android:id="@+id/user_agent_input" android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:hint="WARP for Android" android:inputType="text" android:textColor="#0f172a" android:textColorHint="#94a3b8" android:backgroundTint="#cbd5e1" />
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CF-Client-Version" android:textColor="#475569" android:textSize="11sp" />
                <EditText android:id="@+id/client_version_input" android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:hint="a-6.35-4471" android:inputType="text" android:textColor="#0f172a" android:textColorHint="#94a3b8" android:backgroundTint="#cbd5e1" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="14dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="ZeroTier Mode" android:textColor="#475569" android:textSize="12sp" />
            <Switch android:id="@+id/zero_tier_switch" android:layout_width="wrap_content" android:layout_height="wrap_content" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#e2e8f0" android:layout_marginBottom="12dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Proxy Mode (no VPN permission)" android:textColor="#059669" android:textSize="11sp" android:textStyle="bold" android:layout_marginBottom="8dp" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mode:" android:textColor="#475569" android:textSize="12sp" android:layout_marginEnd="8dp" />
            <Spinner android:id="@+id/proxy_mode_spinner" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:entries="@array/proxy_modes" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Bind Address" android:textColor="#475569" android:textSize="11sp" />
                <EditText android:id="@+id/proxy_bind_input" android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:hint="127.0.0.1" android:inputType="text" android:textColor="#0f172a" android:textColorHint="#94a3b8" android:backgroundTint="#cbd5e1" />
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Port" android:textColor="#475569" android:textSize="11sp" />
                <EditText android:id="@+id/proxy_port_input" android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:hint="8080" android:inputType="number" android:textColor="#0f172a" android:textColorHint="#94a3b8" android:backgroundTint="#cbd5e1" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="10dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Username (opt)" android:textColor="#475569" android:textSize="11sp" />
                <EditText android:id="@+id/proxy_user_input" android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:hint="-" android:inputType="text" android:textColor="#0f172a" android:textColorHint="#94a3b8" android:backgroundTint="#cbd5e1" />
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Password (opt)" android:textColor="#475569" android:textSize="11sp" />
                <EditText android:id="@+id/proxy_pass_input" android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:hint="-" android:inputType="textPassword" android:textColor="#0f172a" android:textColorHint="#94a3b8" android:backgroundTint="#cbd5e1" />
            </LinearLayout>
        </LinearLayout>

        <TextView android:id="@+id/proxy_status_text" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Status: Stopped" android:textColor="#94a3b8" android:textSize="11sp" android:layout_marginBottom="8dp" />

        <Button android:id="@+id/proxy_toggle_button" android:layout_width="match_parent" android:layout_height="44dp"
            android:text="Start Proxy" android:textSize="13sp" android:textColor="#ffffff" android:backgroundTint="#059669" android:layout_marginBottom="14dp" />

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#e2e8f0" android:layout_marginBottom="12dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Zero Trust / Pre-Enrolled" android:textColor="#475569" android:textSize="11sp" android:textStyle="bold" android:layout_marginBottom="8dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Zero Trust JWT" android:textColor="#475569" android:textSize="12sp" android:layout_marginBottom="4dp" />
        <EditText android:id="@+id/jwt_input" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="Cloudflare Zero Trust Token" android:inputType="textMultiLine" android:minLines="2" android:maxLines="3"
            android:textColor="#0f172a" android:textColorHint="#94a3b8" android:backgroundTint="#cbd5e1" android:layout_marginBottom="14dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="License Key" android:textColor="#475569" android:textSize="12sp" android:layout_marginBottom="4dp" />
        <EditText android:id="@+id/license_input" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="WARP+ license key" android:inputType="text"
            android:textColor="#0f172a" android:textColorHint="#94a3b8" android:backgroundTint="#cbd5e1" android:layout_marginBottom="8dp" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Access Token" android:textColor="#475569" android:textSize="11sp" />
                <EditText android:id="@+id/token_input" android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:hint="Token" android:inputType="text" android:textColor="#0f172a" android:textColorHint="#94a3b8" android:backgroundTint="#cbd5e1" />
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Account ID" android:textColor="#475569" android:textSize="11sp" />
                <EditText android:id="@+id/account_id_input" android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:hint="ID" android:inputType="text" android:textColor="#0f172a" android:textColorHint="#94a3b8" android:backgroundTint="#cbd5e1" />
            </LinearLayout>
        </LinearLayout>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="  Fill all 3 to skip new registration" android:textColor="#94a3b8" android:textSize="9sp" android:layout_marginBottom="14dp" />

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#e2e8f0" android:layout_marginBottom="12dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Registered Info (read-only)" android:textColor="#475569" android:textSize="11sp" android:textStyle="bold" android:layout_marginBottom="8dp" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="#f8fafc" android:padding="12dp" android:layout_marginBottom="6dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Device ID" android:textColor="#94a3b8" android:textSize="10sp" />
            <TextView android:id="@+id/registered_device_id" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="(not registered)" android:textSize="11sp" android:textColor="#334155" android:fontFamily="monospace" android:layout_marginBottom="6dp" android:textIsSelectable="true" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="License" android:textColor="#94a3b8" android:textSize="10sp" />
            <TextView android:id="@+id/registered_license" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="(not registered)" android:textSize="11sp" android:textColor="#334155" android:fontFamily="monospace" android:layout_marginBottom="6dp" android:textIsSelectable="true" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Assigned IPv4" android:textColor="#94a3b8" android:textSize="10sp" />
            <TextView android:id="@+id/registered_ipv4" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="(not registered)" android:textSize="11sp" android:textColor="#334155" android:fontFamily="monospace" android:layout_marginBottom="6dp" android:textIsSelectable="true" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Assigned IPv6" android:textColor="#94a3b8" android:textSize="10sp" />
            <TextView android:id="@+id/registered_ipv6" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="(not registered)" android:textSize="11sp" android:textColor="#334155" android:fontFamily="monospace" android:layout_marginBottom="6dp" android:textIsSelectable="true" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Endpoint PubKey" android:textColor="#94a3b8" android:textSize="10sp" />
            <TextView android:id="@+id/registered_pubkey" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="(not registered)" android:textSize="10sp" android:textColor="#334155" android:fontFamily="monospace" android:maxLines="3" android:ellipsize="end" android:textIsSelectable="true" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="8dp">
            <Button android:id="@+id/reenroll_button" android:layout_width="0dp" android:layout_height="40dp"
                android:layout_weight="1" android:text="Re-Enroll Key" android:textSize="11sp" android:textColor="#b91c1c"
                android:backgroundTint="#fee2e2" android:layout_marginEnd="6dp" />
            <Button android:id="@+id/regen_key_button" android:layout_width="0dp" android:layout_height="40dp"
                android:layout_weight="1" android:text="Regen + Enroll" android:textSize="11sp" android:textColor="#b91c1c"
                android:backgroundTint="#fee2e2" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
